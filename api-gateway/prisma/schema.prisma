// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  username       String        @unique
  email          String        @unique
  passwordHash   String
  region         Region
  mmr            Int           @default(1000)
  rank           Rank
  preferredRoles Role[]
  gender         Gender
  createdAt      DateTime      @default(now())
  matches        MatchPlayer[]

  matchPreferences MatchPreference[]
}

model Match {
  id         String        @id @default(uuid())
  region     Region
  type       MatchType
  averageMMR Int
  createdAt  DateTime      @default(now())
  players    MatchPlayer[]
}

model MatchPlayer {
  id      String @id @default(uuid())
  userId  String
  matchId String
  team    Int
  user    User   @relation(fields: [userId], references: [id])
  match   Match  @relation(fields: [matchId], references: [id])
}

model MatchPreference {
  id            String @id @default(uuid())
  userId        String @unique

  preferredGender Gender?
  preferredRole   Role?
  minRank         Rank?
  maxRank         Rank?

  user User @relation(fields: [userId], references: [id])
}

enum Region {
  MUMBAI
  SINGAPORE
  EU
}

enum MatchType {
  DUO
  TEAM5V5
}

enum Rank {
  IRON
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  ASCENDANT
  IMMORTAL
  RADIANT
}

enum Role {
  DUELIST
  SENTINEL
  INITIATOR
  CONTROLLER
}
enum Gender {
  MALE
  FEMALE
  OTHER
}